// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Market {
  id         Int                @id @default(autoincrement())
  name       String             @unique
  code       String             @unique
  activities ActivityOnMarket[]
  metrics    ActivityMetric[]
  createdAt  DateTime           @default(now())
}

model Activity {
  id         Int                @id @default(autoincrement())
  name       String
  startDate  DateTime
  endDate    DateTime
  plan       String
  priceLevel String
  labels          String             @default("[]")
  notes           String?
  pageOnePager    Boolean            @default(false)
  pageCollectOld  Boolean            @default(false)
  pageCollectNew  Boolean            @default(false)
  badgeCopyEn     String?
  badgeCopyLocal  String?
  status          String             @default("未配置")
  notified        Boolean            @default(false)
  product         String             @default("美图秀秀")
  markets    ActivityOnMarket[]
  images     ActivityImage[]
  metrics    ActivityMetric[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model ActivityOnMarket {
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId Int
  market     Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  marketId   Int

  @@id([activityId, marketId])
}

model ActivityImage {
  id         Int      @id @default(autoincrement())
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId Int
  filename   String
  path       String
  createdAt  DateTime @default(now())
}

model DailyMetric {
  id         Int      @id @default(autoincrement())
  date       String   // "YYYY-MM-DD"
  marketCode String
  dau        Float?
  newMembers Float?
  createdAt  DateTime @default(now())

  @@unique([date, marketCode])
}

model ActivityMetric {
  id         Int      @id @default(autoincrement())
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId Int
  market     Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  marketId   Int
  dau        Float?
  revenue    Float?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([activityId, marketId])
}
